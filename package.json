{
  "name": "nexa-music",
  "description": "discord music bot lavalink v4 riffy.",
  "version": "2.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "bun@1.2.8",
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "bun dist/launcher.js",
    "start:bot": "bun dist/index.js",
    "start:node": "node dist/launcher.js",
    "start:bot:node": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,d.ts}\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@top-gg/sdk": "^3.1.1",
    "better-sqlite3": "^11.10.0",
    "discord.js": "^14.21.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.2",
    "genius-lyrics-api": "^3.2.1",
    "pretty-ms": "^9.2.0",
    "riffy": "^1.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "drizzle-kit": "^0.31.4",
    "prettier": "^3.6.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2"
  },
  "keywords": [
    "riffy",
    "music-bot",
    "discord-music-bot",
    "riffy-music-bot",
    "discord-pro-handler",
    "typescript"
  ],
  "author": "KoDdy, Razi (Infinity)",
  "license": "MIT"
}
